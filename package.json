{
  "name": "freshforge",
  "version": "0.2.2",
  "private": true,
  "description": "FreshForge — reusable Cursor AI workflow starter with install, export, and validation CLI",
  "bin": {
    "freshforge": "./bin/freshforge.mjs"
  },
  "scripts": {
    "validate": "npm run validate:structure && npm run validate:markdown && npm run validate:links",
    "validate:starter": "npm run validate:structure && npm run validate:markdown && npm run validate:links",
    "validate:structure": "node scripts/validate-structure.mjs",
    "validate:markdown": "markdownlint-cli2",
    "validate:links": "node scripts/validate-links.mjs",
    "export:starter": "node scripts/export-starter.mjs",
    "export:starter:full": "node scripts/export-starter.mjs --include-readme --include-validation",
    "install:freshforge": "node scripts/install-freshforge.mjs",
    "migrate:dry-run": "node bin/freshforge.mjs migrate --dry-run",
    "doctor": "node bin/freshforge.mjs doctor",
    "validate:migrations": "node scripts/validate-migrations.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.17.2"
  },
  "engines": {
    "node": ">=18"
  }
}
